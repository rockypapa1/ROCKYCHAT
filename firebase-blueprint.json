{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the chat application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier of the user."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "description": "The URL of the user's profile photo."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "phoneNumber": {
          "type": "string",
          "description": "The user's mobile number."
        },
        "lastSeen": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the user was last active."
        },
        "status": {
          "type": "string",
          "enum": ["online", "offline", "away"],
          "description": "The user's current status."
        }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between two or more users.",
      "type": "object",
      "properties": {
        "participants": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array of user UIDs participating in the chat."
        },
        "lastMessage": {
          "type": "string",
          "description": "The text of the last message sent in the chat."
        },
        "lastMessageTime": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the last message."
        },
        "lastMessageSenderId": {
          "type": "string",
          "description": "UID of the user who sent the last message."
        },
        "type": {
          "type": "string",
          "enum": ["direct", "group"],
          "description": "The type of chat."
        }
      },
      "required": ["participants", "type"]
    },
    "Call": {
      "title": "Call",
      "description": "A call between users.",
      "type": "object",
      "properties": {
        "participants": {
          "type": "array",
          "items": { "type": "string" }
        },
        "callerId": { "type": "string" },
        "receiverId": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["ringing", "accepted", "rejected", "ended", "missed"]
        },
        "type": {
          "type": "string",
          "enum": ["audio", "video"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["participants", "callerId", "receiverId", "status", "type", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message within a chat.",
      "type": "object",
      "properties": {
        "chatId": {
          "type": "string",
          "description": "The ID of the chat this message belongs to."
        },
        "senderId": {
          "type": "string",
          "description": "The UID of the user who sent the message."
        },
        "text": {
          "type": "string",
          "description": "The content of the message."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the message was sent."
        },
        "readBy": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array of user UIDs who have read the message."
        }
      },
      "required": ["chatId", "senderId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/chats/{chatId}": {
      "schema": {
        "$ref": "#/entities/Chat"
      },
      "description": "Stores chat conversations."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": {
        "$ref": "#/entities/Message"
      },
      "description": "Stores individual messages within a chat."
    },
    "/calls/{callId}": {
      "schema": {
        "$ref": "#/entities/Call"
      },
      "description": "Stores call records."
    }
  }
}
