rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - email: string (required)
    //   - phoneNumber: string (optional)
    //   - lastSeen: timestamp (optional)
    //   - status: string (optional)
    //
    // Collection: chats
    // Document ID: {chatId}
    // Fields:
    //   - participants: list of strings (required)
    //   - lastMessage: string (optional)
    //   - lastMessageTime: timestamp (optional)
    //   - lastMessageSenderId: string (optional)
    //   - type: string (required)
    //
    // Collection: chats/{chatId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - chatId: string (required)
    //   - senderId: string (required)
    //   - text: string (required)
    //   - createdAt: timestamp (required)
    //   - readBy: list of strings (optional)
    //
    // Collection: calls
    // Document ID: {callId}
    // Fields:
    //   - participants: list of strings (required)
    //   - callerId: string (required)
    //   - receiverId: string (required)
    //   - status: string (required)
    //   - type: string (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !('field' in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    function isUserInChat(chatId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      return hasRequiredFields(['uid', 'displayName', 'email']) &&
             request.resource.data.uid == request.auth.uid &&
             isValidString('displayName', 1, 100) &&
             isValidString('email', 3, 150) &&
             (!('photoURL' in request.resource.data) || isValidString('photoURL', 0, 500)) &&
             (!('phoneNumber' in request.resource.data) || isValidString('phoneNumber', 0, 20)) &&
             (!('status' in request.resource.data) || request.resource.data.status in ['online', 'offline', 'away']);
    }

    function isValidChat() {
      return hasRequiredFields(['participants', 'type']) &&
             request.resource.data.participants is list &&
             request.resource.data.participants.size() >= 2 &&
             request.resource.data.participants.size() <= 100 &&
             request.auth.uid in request.resource.data.participants &&
             request.resource.data.type in ['direct', 'group'] &&
             (!('lastMessage' in request.resource.data) || isValidString('lastMessage', 0, 1000)) &&
             (!('lastMessageSenderId' in request.resource.data) || isValidString('lastMessageSenderId', 0, 100));
    }

    function isValidMessage(chatId) {
      return hasRequiredFields(['chatId', 'senderId', 'text', 'createdAt']) &&
             request.resource.data.chatId == chatId &&
             request.resource.data.senderId == request.auth.uid &&
             isValidString('text', 1, 2000) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidCall() {
      return hasRequiredFields(['participants', 'callerId', 'receiverId', 'status', 'type', 'createdAt']) &&
             request.resource.data.participants is list &&
             request.auth.uid in request.resource.data.participants &&
             (request.resource.data.callerId == request.auth.uid || request.resource.data.receiverId == request.auth.uid) &&
             request.resource.data.status in ['ringing', 'accepted', 'rejected', 'ended', 'missed', 'active'] &&
             request.resource.data.type in ['audio', 'video'] &&
             request.resource.data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser();
      allow update: if isOwner(userId) && isValidUser();
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && isValidChat();
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants && isValidChat();
      
      match /messages/{messageId} {
        allow read: if isUserInChat(chatId);
        allow create: if isUserInChat(chatId) && isValidMessage(chatId);
        allow update: if isUserInChat(chatId) && isValidMessage(chatId);
      }
    }

    match /calls/{callId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && isValidCall() && request.resource.data.callerId == request.auth.uid;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants && isValidCall();

      match /offerCandidates/{id} {
        allow read, write: if isAuthenticated();
      }
      match /answerCandidates/{id} {
        allow read, write: if isAuthenticated();
      }
    }
  }
}
